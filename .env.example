# Copy this file to assets/env/app.env and fill in values,
# or edit assets/env/app.env directly (it is bundled as an asset).
#
# Android emulator:
# - API_BASE_URL=http://10.0.2.2:3003
# - OR API_BASE_URL=http://localhost:3003 + ANDROID_EMULATOR_LOCALHOST=true
#
# Physical device:
# - API_BASE_URL=http://<your-mac-lan-ip>:3003
# - OR (USB) `adb reverse tcp:3003 tcp:3003` + API_BASE_URL=http://127.0.0.1:3003
#
# ANDROID_EMULATOR_LOCALHOST=true
# ANDROID_EMULATOR_HOST_LOOPBACK=10.0.2.2
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
